# ── Formspree ────────────────────────────────────────────────────────
# Formspree Form-ID für das Kontaktformular (https://formspree.io)
# Wird als Fallback genutzt, falls config.json keinen Wert liefert
VITE_FORMSPREE_ID=xpwdjokn

# ── Temperatur-API ──────────────────────────────────────────────────
# Basis-URL der Freibad-API für Temperaturdaten
# Wird in useTemperatur.ts für fetch()-Aufrufe genutzt
VITE_API_BASE_URL=https://api.freibad-haselbach.de

# ── Bilder / CDN ────────────────────────────────────────────────────
# Basis-URL für gehostete Bilder (z.B. Cloudflare Images, Imgur, etc.)
# Relative Bildpfade aus den JSON-Dateien werden mit diesem Prefix versehen
# Absolute URLs (https://...) in den JSONs werden direkt genutzt
VITE_IMAGE_BASE_URL=https://imagedelivery.net/ACCOUNT_HASH

# ── Sonstige ────────────────────────────────────────────────────────
# Seitenname – wird als document.title gesetzt (Fallback: config.json → vereinsname)
VITE_SITE_TITLE=Freibad Haselbach e.V.

# Umgebung (development | production)
VITE_ENV=development
